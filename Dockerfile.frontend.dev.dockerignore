## Build context for Dockerfile.frontend.dev
## Docker BuildKit uses this file instead of .dockerignore for this Dockerfile.
## We need frontend/ (for package.json / pnpm-lock.yaml), so we do NOT exclude it.

# Version control
.git/
.gitignore

# Python artifacts & source (not needed for frontend image)
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
src/

# Testing / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# Dev tooling
.stack/
*.log

# Secrets
.env
.env.*

# Docs / design (large, not needed)
docs/
Research/

# Subprojects
subprojects/

# IDE
.vscode/
