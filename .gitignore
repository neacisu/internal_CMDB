# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/

# Build and packaging outputs
build/
dist/
*.egg-info/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type checker and linter caches
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# IDE/editor
.vscode/*.code-workspace
.idea/
.cursor/
.DS_Store

# Security and scan reports
*.sarif

# Local environment and secrets
.env
.env.*
!.env.example
.secrets/

# Runtime logs and temporary outputs
*.log
tmp/
.tmp/
subprojects/**/results/

# Local database and migration artifacts
*.sqlite3
*.db
pgdata/
postgres-data/
alembic.ini.local
