# internalCMDB — environment configuration template
# Copy to .env and fill in your values.  NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL connection
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=internalCMDB
POSTGRES_USER=internalcmdb
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_SSLMODE=prefer

# ---------------------------------------------------------------------------
# Application settings
# ---------------------------------------------------------------------------
# Alembic database URL (override if using a different connection format)
# DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Log format: json (production) | dev (coloured console)
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
# OTLP collector endpoint
OTLP_ENDPOINT=http://localhost:4317
# Protocol: grpc | http
OTLP_PROTOCOL=grpc
# Set to false to require TLS
OTLP_INSECURE=true
# Sampling rate 0.0–1.0 (1.0 = trace everything, 0.1 = 10%)
OTEL_SAMPLE_RATE=1.0

# ---------------------------------------------------------------------------
# Debug endpoints
# ---------------------------------------------------------------------------
# Set to false to disable /api/v1/debug/* in production
DEBUG_ENABLED=true

# ---------------------------------------------------------------------------
# pgvector / embedding
# ---------------------------------------------------------------------------
# Embedding model code used by the chunker and ranker
EMBEDDING_MODEL_CODE=qwen3-embedding-8b-q5km
# Embedding vector dimension (must match the model; Qwen3-Embedding-8B produces dim=4096)
EMBEDDING_VECTOR_DIM=4096

# ---------------------------------------------------------------------------
# Agent control
# ---------------------------------------------------------------------------
# Identity code stamped on automated agent runs
AGENT_IDENTITY=internalcmdb-agent-v1

# ---------------------------------------------------------------------------
# Security / secrets
# ---------------------------------------------------------------------------
# Secret key used for HMAC signing of audit tokens (min 32 chars)
SECRET_KEY=change_me_to_a_random_32_char_or_longer_value

# ---------------------------------------------------------------------------
# OpenBao / Vault integration (optional — falls back to env vars above)
# ---------------------------------------------------------------------------
# VAULT_ADDR=https://openbao.internal:8200
# VAULT_TOKEN=hvs.your-vault-token-here
# VAULT_SECRET_MOUNT=secret
# VAULT_SECRET_PATH=internalcmdb
# VAULT_TIMEOUT=10
# VAULT_CACHE_TTL=300

# ---------------------------------------------------------------------------
# Redis (shared rate-limit counters, ARQ worker queue)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth / JWT  (standalone — no Zitadel / external IdP)
# ---------------------------------------------------------------------------
# REQUIRED: minimum 32 chars; use OpenBao / Vault in production
JWT_SECRET_KEY=change_me_min_32_chars_use_openbao_in_production

# Algorithm — HS256 is the only supported value
JWT_ALGORITHM=HS256

# Access token TTL in minutes (default 120 = 2 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Set to true in production (requires HTTPS)
JWT_COOKIE_SECURE=true

# SameSite policy for the session cookie: strict | lax | none
JWT_COOKIE_SAMESITE=lax

# Set to false ONLY for debugging — exposes tokens to JavaScript
JWT_COOKIE_HTTPONLY=true

# Disable all auth checks (NEVER true in production)
AUTH_DEV_MODE=false

# ---------------------------------------------------------------------------
# REMOVED — Zitadel / OIDC integration no longer used
# The following vars are intentionally absent.  Do NOT add them back.
#   ZITADEL_ISSUER
#   ZITADEL_JWKS_URL
#   RBAC_ROLES_CLAIM
#   RBAC_DEV_MODE
#   JWKS_CACHE_TTL
# ---------------------------------------------------------------------------
