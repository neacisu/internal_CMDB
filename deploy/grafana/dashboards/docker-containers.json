        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "count(count by (name, instance) (container_memory_usage_bytes{instance=~\"$host\", name!=\"\"}))",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Running containers",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "description": "Heuristică cAdvisor: last_seen minus containere cu memorie raportată (poate fi 0 dacă last_seen nu include oprite).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "clamp_min(count(count by (name, instance) (container_last_seen{instance=~\"$host\", name!=\"\"})) - count(count by (name, instance) (container_memory_usage_bytes{instance=~\"$host\", name!=\"\"})), 0)",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Stopped containers (estimate)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [{ "id": "unit", "value": "percent" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Network B/s" },
            "properties": [{ "id": "unit", "value": "Bps" }]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": { "color": "red", "index": 1, "text": "Stopped" },
                      "1": { "color": "green", "index": 0, "text": "Running" }
                    },
                    "type": "value"
                  }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 11, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Memory" }]
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "label_join(max by (name, instance) (container_last_seen{instance=~\"$host\", name!=\"\"}), \"container_uid\", \"::\", \"instance\", \"name\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "label_join(max by (name, instance, image) (container_memory_usage_bytes{instance=~\"$host\", name!=\"\"}), \"container_uid\", \"::\", \"instance\", \"name\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "label_join(sum by (name, instance, image) (rate(container_cpu_usage_seconds_total{instance=~\"$host\", name!=\"\"}[5m])) * 100, \"container_uid\", \"::\", \"instance\", \"name\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "label_join((sum without (interface) (rate(container_network_receive_bytes_total{instance=~\"$host\", name!=\"\"}[5m])) + sum without (interface) (rate(container_network_transmit_bytes_total{instance=~\"$host\", name!=\"\"}[5m]))) * on (name, instance) group_left (image) (max by (name, instance, image) (container_memory_usage_bytes{instance=~\"$host\", name!=\"\"}) * 0 + 1), \"container_uid\", \"::\", \"instance\", \"name\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus" },
          "editorMode": "code",
          "expr": "label_join(max by (name, instance) ((container_memory_usage_bytes{instance=~\"$host\", name!=\"\"} > bool 0)), \"container_uid\", \"::\", \"instance\", \"name\")",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "E"
        }
      ],
      "title": "All containers",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "container_uid", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Value #A": true,
              "__name__": true,
              "container_uid": true,
              "id": true,
              "job": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #B": "Memory",
              "Value #C": "CPU %",
              "Value #D": "Network B/s",
              "Value #E": "Status"
            }
          }
        }
      ],
      "type": "table"
